{
  "name": "context-mode-cli",
  "version": "1.0.52-p1",
  "private": false,
  "description": "Thin Bun CLI wrapper for calling the shared context-mode MCP server",
  "license": "Elastic-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/runtime-intel/context-mode-cli.git"
  },
  "homepage": "https://github.com/runtime-intel/context-mode-cli#readme",
  "bugs": {
    "url": "https://github.com/runtime-intel/context-mode-cli/issues"
  },
  "keywords": [
    "bun",
    "cli",
    "context-mode",
    "mcp"
  ],
  "packageManager": "bun@1.3.10",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "context-mode-cli": "./bin/context-mode-cli.mjs"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1"
  },
  "scripts": {
    "check": "bun --eval \"JSON.parse(await Bun.file('package.json').text()); console.log('package.json ok')\"",
    "pack": "bun pm pack --destination dist"
  }
}
